# Copy this file to `.env.local` and fill in real values.

# The password you'll use to log in at /admin
# CHANGE THIS to something long and unique. Do NOT share it.
ADMIN_PASSWORD=change-me-to-something-secure

# A random string used to sign your admin session cookie.
# Generate one by running:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Where the SQLite database file lives. Leave as-is for local dev.
# On Vercel/serverless you should use a managed DB — see README for guidance.
DATABASE_PATH=./data/niche-network.db
